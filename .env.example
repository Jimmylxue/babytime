# ============ 数据库配置 ============
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=baby_time

# ============ JWT ============
JWT_SECRET=your-super-secret-jwt-key

# ============ 微信小程序 ============
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 小程序代码上传密钥文件路径（用于 mini.sh 部署脚本）
PRIVATE_KEY_PATH=.miniprogram.key

# ============ 文件上传 ============
# 上传驱动: local | upyun
UPLOAD_DRIVER=local

# 又拍云配置（UPLOAD_DRIVER=upyun 时需要）
UPYUN_OPERATOR=
UPYUN_PASSWORD=
UPYUN_BUCKET=
UPYUN_DOMAIN=https://xxx.upcdn.net

# ============ 服务端口 ============
PORT=3000
